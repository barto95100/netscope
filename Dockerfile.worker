# Stage 1: Build Go worker binary
FROM golang:1.25-alpine AS build
RUN apk add --no-cache git
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /netscope-worker ./cmd/worker

# Stage 2: Runtime
FROM alpine:3.20
RUN apk add --no-cache ca-certificates git traceroute iputils nmap
WORKDIR /app
COPY --from=build /netscope-worker .

ENTRYPOINT ["./netscope-worker"]
